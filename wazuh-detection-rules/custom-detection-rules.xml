<!--
  Custom Wazuh Detection Rules — SOC-LAB
  Author: Oscar Njumbe | Security Operations Engineer
  Environment: Wazuh Manager deployed on Proxmox homelab
  All rules mapped to MITRE ATT&CK

  Deployment: Place in /var/ossec/etc/rules/local_rules.xml
  Rule ID range: 100001–100099 (reserved for SOC-LAB custom rules)
-->

<group name="soc-lab,">

  <!-- ============================================================
       Rule 100001 — SSH Brute Force Detection
       Fires when 8 or more SSH authentication failures occur from
       the same source within a 120-second window.
       MITRE ATT&CK: T1110.001 — Brute Force: Password Guessing
       ============================================================ -->
  <rule id="100001" level="10" frequency="8" timeframe="120">
    <if_matched_sid>5716</if_matched_sid>
    <description>SOC-LAB: SSH brute force attack — $(srcip) exceeded failure threshold (T1110.001)</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>authentication_failures,brute_force,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

  <!-- ============================================================
       Rule 100002 — Unauthorised Sudo Escalation Attempt
       Detects sudo usage by users not in the sudoers file.
       Level 12 = critical; triggers immediate alert to SOAR pipeline.
       MITRE ATT&CK: T1548.003 — Abuse Elevation Control: Sudo
       ============================================================ -->
  <rule id="100002" level="12">
    <if_sid>5402</if_sid>
    <match>sudo</match>
    <regex>user NOT in sudoers|Command not allowed|authentication failure</regex>
    <description>SOC-LAB: Unauthorised sudo escalation attempt by $(user) on $(hostname) (T1548.003)</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
    <group>privilege_escalation,pci_dss_10.2.5,gpg13_7.3,</group>
  </rule>

  <!-- ============================================================
       Rule 100003 — Executable Staged in /tmp
       Detects creation of script/executable files in world-writable
       directories — common staging pattern for initial access payloads.
       MITRE ATT&CK: T1059 (Scripting), T1105 (Ingress Tool Transfer)
       ============================================================ -->
  <rule id="100003" level="8">
    <if_sid>554</if_sid>
    <field name="file" type="pcre2">/tmp/.*\.(sh|py|pl|rb|elf|bin|out)$</field>
    <description>SOC-LAB: Executable file created in /tmp — potential staging (T1059/T1105): $(file)</description>
    <mitre>
      <id>T1059</id>
      <id>T1105</id>
    </mitre>
    <group>suspicious_file,attack,pci_dss_11.5,</group>
  </rule>

  <!-- ============================================================
       Rule 100004 — New Local User Account Created
       Any new local account creation requires review. Attackers
       commonly create backdoor accounts for persistence.
       MITRE ATT&CK: T1136.001 — Create Account: Local Account
       ============================================================ -->
  <rule id="100004" level="10">
    <if_sid>5901</if_sid>
    <description>SOC-LAB: New local user account created on $(hostname) — review required (T1136.001)</description>
    <mitre>
      <id>T1136.001</id>
    </mitre>
    <group>account_creation,pci_dss_10.2.5,gpg13_7.3,gdpr_IV_35.7.d,</group>
  </rule>

</group>
